# HydroGuide Backend Configuration
# Copy this file to .env and fill in the values

# Database (SQLite path - relative to backend/ or absolute)
DATABASE_URL=sqlite+aiosqlite:///./data/hydroguide.db

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Session cookie settings
SESSION_COOKIE_NAME=hydroguide_session
SESSION_MAX_AGE_DAYS=365

# API authentication (for public REST API)
API_BEARER_TOKEN=changeme-generate-a-real-token

# AI service (for future use)
# AI_API_KEY=
# AI_MODEL=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
